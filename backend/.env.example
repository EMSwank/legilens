DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/legilens
REDIS_URL=redis://localhost:6379
LEGISCAN_API_KEY=your_key_here
# Local dev: relative path under backend/ is fine.
# Prod (Railway): set to absolute path on persistent volume, e.g. /data/zip_cache.
LEGISCAN_ZIP_CACHE_DIR=./var/zip_cache
ALLOWED_ORIGINS=http://localhost:3000
